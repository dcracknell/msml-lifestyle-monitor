{
  "name": "lifestyle-dashboard",
  "version": "1.0.0",
  "description": "Fitbit-style lifestyle monitor web experience with shared auth for web and app clients.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "node scripts/ensure-native-deps.js",
    "predev": "node scripts/ensure-native-deps.js",
    "dev": "nodemon src/server.js",
    "prestart": "node scripts/ensure-native-deps.js",
    "start": "node src/server.js",
    "pretest": "node scripts/ensure-native-deps.js",
    "test": "jest",
    "prereset-db": "node scripts/ensure-native-deps.js",
    "reset-db": "node scripts/reset-db.js",
    "stop": "node scripts/kill-port.js",
    "prerestart": "node scripts/ensure-native-deps.js",
    "restart": "node scripts/kill-port.js && node src/server.js",
    "prereset": "node scripts/ensure-native-deps.js",
    "reset": "node scripts/reset-db.js && node scripts/kill-port.js && node src/server.js",
    "check:nut-model": "bash ./scripts/check-nut-model.sh",
    "setup:ppg-model": "bash ./scripts/setup-ppg-model.sh",
    "check:ppg-model": "bash ./scripts/check-ppg-model.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.19.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
