# HTTP port exposed by Express
PORT=4000
# Interface Express binds to (0.0.0.0 = all network interfaces)
HOST=0.0.0.0
# Max HTTP JSON body size accepted by Express (must exceed base64 photo payload)
API_BODY_LIMIT=20mb
# Comma-separated list of allowed browser origins (e.g., local + msmls.org)
APP_ORIGIN=http://localhost:4000,http://192.168.1.50:4000,https://msmls.org,https://www.msmls.org
# Session/token lifetime in hours
SESSION_TTL_HOURS=12
# Long random secret used for token encryption
SESSION_SECRET=replace-me-with-a-strong-secret
# SQLite storage + seed directories (absolute or relative paths)
DB_STORAGE_DIR=./database/storage
DB_SQL_DIR=./database/sql
# Optional overrides for passwords baked into the SQL seed (if you choose to override them)
HEAD_COACH_SEED_PASSWORD=Password
COACH_SEED_PASSWORD=Password
ATHLETE_SEED_PASSWORD=Password

# ── NUT speed mode ────────────────────────────────────────────────────────────
# HIGH ACCURACY (default): spawns a fresh Python process per request (~30-45 s).
# EXPRESS MODE: set NUT_EXPRESS_MODE=true and run nut_server.py alongside Node.
#   The sidecar keeps the model in memory and parallelises USDA lookups (~3-8 s).
#   Start: /path/to/NUT_model/.venv/bin/python NUT_model/nut_server.py
#   Stop (revert): remove this line (or set false) and stop nut_server.py.
# NUT_EXPRESS_MODE=true
# NUT_EXPRESS_URL=http://localhost:8001
# NUT_EXPRESS_PORT=8001   # port nut_server.py listens on
# ──────────────────────────────────────────────────────────────────────────────

# Optional NUT model runtime overrides
NUT_MODEL_PYTHON_BIN=python
NUT_MODEL_SCRIPT=./server/NUT_model/nut_estimator.py
NUT_MODEL_WEIGHTS=./server/NUT_model/canet_NUT.pth
# Optional: custom labels JSON (defaults to built-in FoodSeg103 labels)
# NUT_MODEL_LABELS=./server/NUT_model/foodseg103_labels.json
NUT_MODEL_TIMEOUT_MS=45000
NUT_MODEL_IMAGE_SIZE=320
NUT_MODEL_SETUP_CACHE_TTL_MS=3600000
NUT_MODEL_MAX_PHOTO_BASE64_LENGTH=12582912
# Confidence floors used to reject uncertain photo guesses
NUT_MODEL_MIN_CONFIDENCE=0.75
NUT_MODEL_STRICT_MIN_CONFIDENCE=0.80
NUT_MODEL_MULTI_MIN_CONFIDENCE=0.08
NUT_MODEL_STRICT_MULTI_MIN_CONFIDENCE=0.18
NUT_MODEL_MULTI_MAX_ITEMS=6
NUT_MODEL_PRESERVE_ASPECT=true
NUT_MODEL_ENABLE_TTA=false
NUT_MODEL_ENABLE_IMAGENET_FALLBACK=true
NUT_MODEL_IMAGENET_MIN_CONFIDENCE=0.25
NUT_MODEL_IMAGENET_MIN_MARGIN=1.15
NUT_MODEL_IMAGENET_MIN_GENERIC_CONFIDENCE=0.40
NUT_MODEL_IMAGENET_TOP_K=8
